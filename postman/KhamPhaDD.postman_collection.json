		{
			"name": "2. Authentication",
			"item": [
				{
					"name": "Get CSRF Cookie & Login Page",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const xsrf = pm.cookies.get('XSRF-TOKEN');",
									"if (xsrf) {",
									"    pm.environment.set('xsrf_token', decodeURIComponent(xsrf));",
									"    console.log('CSRF Token updated in Environment: ' + decodeURIComponent(xsrf));",
									"} else {",
									"    console.log('XSRF-TOKEN cookie not found in response jar. Make sure Laravel dev server is running and returning cookies.');",
									"}"
								],
								"type": "javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"login"
							]
						},
						"description": "Gọi để Laravel thiết lập session cookie và CSRF cookie trong Cookie Jar của Postman. Đồng thời tự động cập nhật biến `xsrf_token` trên Postman Environment."
					},
					"response": []
				},
